# 复制本文件重命名为 .env，并在下方填入你的 API Key。
# workflow.py 启动时会自动加载这里的配置。

# ==========================================================
# 针对 MiniMax 接口的配置 (以 minimax-text-01 也就是类似 minimax2.7 的模型为例)
# ==========================================================

# 1. 在这里填入你在 MiniMax 平台获取的 API Key
OPENAI_API_KEY=在此处填写你的_MiniMax_API_Key

# 2. 设置 MiniMax 兼容 OpenAI 格式的 base_url
OPENAI_BASE_URL=https://api.minimax.chat/v1

# 3. 指定 MiniMax 的模型名称 (支持的具体模型名请参考 MiniMax 官方文档)
# 常见的如 abab6.5s-chat, abab6.5-chat, minimax-text-01 等。
OPENAI_MODEL=abab6.5s-chat
