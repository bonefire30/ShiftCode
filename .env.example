# OpenAI-compatible API configuration
# Current provider example: DeepSeek

# 1. API key
OPENAI_API_KEY=your_deepseek_api_key

# 2. OpenAI-compatible base URL
OPENAI_BASE_URL=https://api.deepseek.com

# 3. Model
OPENAI_MODEL=deepseek-v4-flash

# JAVA2GO evaluation LLM profiles
# Real API keys must be set locally only. Do not commit real values.
MINIMAX_API_KEY=your_minimax_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
CODEX_PROXY_API_KEY=your_codex_proxy_api_key

# Optional provider endpoints when they are OpenAI-compatible in your environment.
# Leave unset unless the provider endpoint is known for your account.
MINIMAX_BASE_URL=
DEEPSEEK_BASE_URL=

# Unit-test/local dry-run path that avoids real LLM API calls.
JAVA2GO_LLM_MOCK=0
